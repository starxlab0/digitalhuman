<!-- 主容器 -->
<view class="container">

  <!-- 调试提示（初始化完成后可隐藏） -->
  <view class="debug-box" wx:if="{{debugText}}">
    <text>{{debugText}}</text>
  </view>

  <!-- 数字人区域 -->
  <view class="avatar-area">
    <!-- Canvas 面部渲染（独立组件，避免 _getData 错误） -->
    <avatar-canvas
      wx:if="{{canvasReady}}"
      id="avatar"
      bindtouchstart="onAvatarTouchStart"
      bindtap="onAvatarTap"
    ></avatar-canvas>

    <!-- 语音气泡 -->
    <view class="speech-bubble {{bubbleShow ? 'show' : ''}}">
      <text>{{bubbleText}}</text>
    </view>

    <!-- 语音状态指示器 -->
    <view class="voice-indicator {{voiceActive ? 'active' : ''}}">
      <view class="wave">
        <view class="bar"></view><view class="bar"></view>
        <view class="bar"></view><view class="bar"></view><view class="bar"></view>
      </view>
      <text class="hint">{{voiceHint}}</text>
    </view>
  </view>

  <!-- 底部控制面板 -->
  <view class="control-panel">
    <!-- 表情按钮 -->
    <view class="expr-row">
      <view class="expr-btn {{currentExpr==='neutral'?'on':''}}"  data-expr="neutral"  bindtap="setExpr">😐</view>
      <view class="expr-btn {{currentExpr==='happy'?'on':''}}"    data-expr="happy"    bindtap="setExpr">😄</view>
      <view class="expr-btn {{currentExpr==='sad'?'on':''}}"      data-expr="sad"      bindtap="setExpr">😢</view>
      <view class="expr-btn {{currentExpr==='surprised'?'on':''}}" data-expr="surprised" bindtap="setExpr">😲</view>
      <view class="expr-btn {{currentExpr==='angry'?'on':''}}"    data-expr="angry"    bindtap="setExpr">😠</view>
    </view>
    <view class="expr-row">
      <view class="expr-btn {{currentExpr==='wink'?'on':''}}"  data-expr="wink"  bindtap="setExpr">😉</view>
      <view class="expr-btn {{currentExpr==='love'?'on':''}}"  data-expr="love"  bindtap="setExpr">😍</view>
      <view class="expr-btn {{currentExpr==='cool'?'on':''}}"  data-expr="cool"  bindtap="setExpr">😎</view>
      <view class="expr-btn {{currentExpr==='silly'?'on':''}}" data-expr="silly" bindtap="setExpr">😜</view>
      <view class="expr-btn {{currentExpr==='sleepy'?'on':''}}" data-expr="sleepy" bindtap="setExpr">😴</view>
    </view>

    <!-- 功能按钮 -->
    <view class="action-row">
      <view class="action-btn {{voiceRecording?'listening':''}}" bindtap="toggleVoice">
        <text class="icon">🎤</text>
        <text class="label">语音</text>
      </view>
      <view class="action-btn {{autoMode?'on':''}}" bindtap="toggleAuto">
        <text class="icon">🔄</text>
        <text class="label">自动</text>
      </view>
      <view class="action-btn {{lang==='zh-HK'?'on':''}}" bindtap="toggleLang">
        <text class="icon">{{lang==='zh-HK' ? '🇭🇰' : '🇨🇳'}}</text>
        <text class="label">{{langLabel}}</text>
      </view>
    </view>
  </view>

</view>

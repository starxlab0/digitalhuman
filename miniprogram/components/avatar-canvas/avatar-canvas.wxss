:host {
  display: block;
  width: 100%;
  height: 100%;
}

.avatar-wrap {
  width: 100%;
  height: 100%;
  position: relative;
}

.avatar-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-status {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 16rpx 32rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  pointer-events: none;
  white-space: nowrap;
  z-index: 10;
}
